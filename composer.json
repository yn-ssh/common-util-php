{
    "name": "ssh/common-util",
    "description": "PHP 常用工具类集合，包含阿里云IoT/OSS/SMS、国密SM2/SM3/SM4加解密、AES加解密、商米云打印等工具",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "aliyun",
        "iot",
        "oss",
        "sms",
        "sm2",
        "sm3",
        "sm4",
        "sm-crypto",
        "aes",
        "sunmi",
        "printer",
        "utility"
    ],
    "authors": [
        {
            "name": "wrkj",
            "email": "694711507@qq.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "workerman/webman-framework": "^2.0",
        "psr/log": "^2.0 || ^3.0",
        "alibabacloud/credentials": "^1.2",
        "alibabacloud/iot-20180120": "^5.0",
        "alibabacloud/oss-v2": "^0.4.0",
        "alibabacloud/dysmsapi-20170525": "^4.0",
        "lpilp/guomi": "^2.0",
        "ext-curl": "*",
        "ext-openssl": "*",
        "ext-gmp": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "suggest": {
        "ext-gd": "商米云打印图片处理需要GD扩展"
    },
    "autoload": {
        "psr-4": {
            "Ssh\\CommonUtil\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ssh\\CommonUtil\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
